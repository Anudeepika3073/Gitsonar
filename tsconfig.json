{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "rootDir": "./",
    "baseUrl": "./",
    "allowJs": true,
    "esModuleInterop": true,
    "inlineSources": true,
    "inlineSourceMap": true,
    "moduleResolution": "node",
    "paths": {
      "#cds-models/*": [
        "./@cds-models/*"
      ]
    },
    "types": [
      "jest",
      "node",
      "@cap-js/cds-types"
    ]
  },
  "include": [
    "./srv/**/*"
  ]
}
